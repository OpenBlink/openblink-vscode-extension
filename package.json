{
  "name": "openblink-extension",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.3.5",
  "engines": {
    "vscode": "^1.96.0"
  },
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenBlink/openblink-vscode-extension"
  },
  "publisher": "OpenBlink",
  "icon": "resources/icons/openblink.png",
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "mruby",
    "ble",
    "bluetooth",
    "microcontroller",
    "iot"
  ],
  "homepage": "https://github.com/OpenBlink/openblink-vscode-extension",
  "bugs": {
    "url": "https://github.com/OpenBlink/openblink-vscode-extension/issues"
  },
  "l10n": "./l10n",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "This extension compiles and transfers code to hardware devices over BLE. It requires a trusted workspace."
    },
    "virtualWorkspaces": false
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openblink.connectDevice",
        "title": "%command.connectDevice%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.disconnectDevice",
        "title": "%command.disconnectDevice%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.buildAndBlink",
        "title": "%command.buildAndBlink%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.softReset",
        "title": "%command.softReset%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.selectSourceFile",
        "title": "%command.selectSourceFile%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.selectBoard",
        "title": "%command.selectBoard%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.selectSlot",
        "title": "%command.selectSlot%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.scanDevices",
        "title": "%command.scanDevices%",
        "category": "OpenBlink",
        "icon": "$(search)"
      },
      {
        "command": "openblink.stopScan",
        "title": "%command.stopScan%",
        "category": "OpenBlink",
        "icon": "$(debug-stop)"
      },
      {
        "command": "openblink.connectScannedDevice",
        "title": "%command.connectDevice%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.connectSavedDevice",
        "title": "%command.connectDevice%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.forgetDevice",
        "title": "%command.forgetDevice%",
        "category": "OpenBlink",
        "icon": "$(trash)"
      },
      {
        "command": "openblink.setupMcp",
        "title": "%command.setupMcp%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.installMcpWorkspace",
        "title": "%command.installMcpWorkspace%",
        "category": "OpenBlink"
      },
      {
        "command": "openblink.clearMcpHistory",
        "title": "%command.clearMcpHistory%",
        "category": "OpenBlink",
        "icon": "$(clear-all)"
      }
    ],
    "configuration": {
      "title": "OpenBlink",
      "properties": {
        "openblink.slot": {
          "type": "number",
          "default": 2,
          "enum": [
            1,
            2
          ],
          "description": "%config.slot%"
        },
        "openblink.sourceFile": {
          "type": "string",
          "default": "app.rb",
          "description": "%config.sourceFile%"
        },
        "openblink.board": {
          "type": "string",
          "default": "",
          "description": "%config.board%"
        },
        "openblink.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.mcp.enabled%"
        },
        "openblink.ble.writeTimeout": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "%config.ble.writeTimeout%"
        },
        "openblink.ble.scanTimeout": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "%config.ble.scanTimeout%"
        },
        "openblink.ble.connectionTimeout": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "%config.ble.connectionTimeout%"
        },
        "openblink.ble.maxReconnectAttempts": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 20,
          "description": "%config.ble.maxReconnectAttempts%"
        },
        "openblink.ble.initialReconnectDelay": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.ble.initialReconnectDelay%"
        },
        "openblink.ble.requestedMtu": {
          "type": "number",
          "default": 512,
          "minimum": 23,
          "maximum": 1024,
          "description": "%config.ble.requestedMtu%"
        },
        "openblink.ble.defaultMtu": {
          "type": "number",
          "default": 20,
          "minimum": 7,
          "maximum": 512,
          "description": "%config.ble.defaultMtu%"
        },
        "openblink.mcp.statusDebounce": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.mcp.statusDebounce%"
        },
        "openblink.mcp.consoleDebounce": {
          "type": "number",
          "default": 2000,
          "minimum": 100,
          "maximum": 10000,
          "description": "%config.mcp.consoleDebounce%"
        },
        "openblink.console.bufferSize": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "%config.console.bufferSize%"
        },
        "openblink.metrics.historySize": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "%config.metrics.historySize%"
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "openblink.mcpServer",
        "label": "OpenBlink"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openblink-explorer",
          "title": "OpenBlink",
          "icon": "resources/icons/openblink.svg"
        }
      ]
    },
    "views": {
      "openblink-explorer": [
        {
          "id": "openblink-devices",
          "name": "%view.devices%"
        },
        {
          "id": "openblink-tasks",
          "name": "%view.tasks%"
        },
        {
          "id": "openblink-device-info",
          "name": "%view.deviceInfo%"
        },
        {
          "id": "openblink-metrics",
          "name": "%view.metrics%"
        },
        {
          "id": "openblink-board-reference",
          "name": "%view.boardReference%"
        },
        {
          "id": "openblink-mcp-status",
          "name": "%view.mcpStatus%"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .rb",
          "command": "openblink.selectSourceFile",
          "group": "openblink"
        }
      ],
      "view/title": [
        {
          "command": "openblink.scanDevices",
          "when": "view == openblink-devices",
          "group": "navigation"
        },
        {
          "command": "openblink.stopScan",
          "when": "view == openblink-devices",
          "group": "navigation"
        },
        {
          "command": "openblink.clearMcpHistory",
          "when": "view == openblink-mcp-status",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "openblink.forgetDevice",
          "when": "view == openblink-devices && viewItem == savedDevice",
          "group": "inline"
        },
        {
          "command": "openblink.forgetDevice",
          "when": "view == openblink-devices && viewItem == savedDevice-connected",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run compile",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile-tests": "tsc -p .",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/l10n-dev": "^0.0.35",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.2.0",
    "ovsx": "^0.10.11",
    "ts-loader": "^9.5.2",
    "typescript": "^6.0.2",
    "webpack": "^5.98.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/l10n": "^0.0.18",
    "zod": "^3.25.0"
  }
}
